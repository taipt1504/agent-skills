{
  "$schema": "./devco-config.schema.json",
  "version": "3.3.1",
  "mode": "standard",
  "workflow": {
    "skipPlanConfirm": false,
    "skipSpecConfirm": false,
    "autoVerify": true,
    "autoReview": true,
    "maxRetryOnFail": 3,
    "maxIterationsPerPhase": 10,
    "noProgressThreshold": 3
  },
  "skills": {
    "autoLoad": true,
    "profile": "standard"
  },
  "hooks": {
    "profile": "standard"
  },
  "traces": {
    "retentionDays": 7,
    "schemaVersion": 2
  },
  "team": {
    "enabled": false,
    "mode": "subagent",
    "maxTeammates": 4,
    "spawnStrategy": "smart",
    "roles": {
      "implementer": { "model": "sonnet", "maxConcurrent": 3 },
      "reviewer": { "model": "sonnet", "maxConcurrent": 2 },
      "tester": { "model": "sonnet", "maxConcurrent": 2 }
    },
    "costControl": {
      "preferFastModel": true,
      "useOpusOnlyFor": ["plan", "spec", "architecture"]
    }
  }
}
