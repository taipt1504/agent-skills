{
  "$schema": "../schemas/hooks.schema.json",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start.sh\"",
            "timeout": 30
          }
        ],
        "description": "Load previous session context, detect project structure (Maven/Gradle), and restore continuity"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/suggest-compact.sh\"",
            "timeout": 5,
            "async": true
          }
        ],
        "description": "Monitor context window usage and suggest /compact at logical boundaries"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/java-compile-check.sh\"",
            "timeout": 90
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/java-format.sh\"",
            "timeout": 60,
            "async": true
          }
        ],
        "description": "Validate Java compilation and auto-format after file edits"
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/pre-compact.sh\"",
            "timeout": 30,
            "async": true
          }
        ],
        "description": "Save architectural decisions, current task state, and learnings before context compaction"
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/check-debug-statements.sh\"",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/cost-tracker.sh\"",
            "timeout": 10,
            "async": true
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-end.sh\"",
            "timeout": 60,
            "async": true
          }
        ],
        "description": "Check debug statements, track costs, and persist session state"
      }
    ]
  }
}
